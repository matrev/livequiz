# Public GraphQL endpoint used by Apollo HttpLink (browser + SSR).
# Set this to your deployed backend GraphQL URL.
NEXT_PUBLIC_GRAPHQL_HTTP_URL=http://localhost:4000/graphql

# Public GraphQL subscriptions endpoint used by graphql-ws (browser only).
# Use wss:// in production when serving over HTTPS.
NEXT_PUBLIC_GRAPHQL_WS_URL=ws://localhost:4000/subscriptions
