# Server bind host.
# Use 0.0.0.0 for containers/platform deployments.
HOST=0.0.0.0

# Server bind port.
PORT=4000

# PostgreSQL connection string used by Prisma.
# Add SSL params if your provider requires them.
# Example:
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=

# Base URL of the frontend application used to generate links in emails.
# When set, this value is always used.
# When unset, defaults to https://livequiz.marktrevino.com in production
# (NODE_ENV=production) and http://localhost:3000 otherwise.
FRONTEND_BASE_URL=http://localhost:3000

# Comma-separated list of allowed CORS origins for /graphql.
# Example:
# CORS_ORIGINS=https://app.example.com,https://www.app.example.com
#
# In development, if empty, defaults to http://localhost:3000.
# In production, if empty, all browser origins are denied by default.
CORS_ORIGINS=http://localhost:3000

# Email sending provider.
# Supported values: resend, http-api
EMAIL_PROVIDER=resend

# Shared sender address used by providers.
EMAIL_FROM=no-reply@example.com

# Resend provider API key (required when EMAIL_PROVIDER=resend).
RESEND_API_KEY=

# Generic HTTP API provider settings (required when EMAIL_PROVIDER=http-api).
EMAIL_API_ENDPOINT=
EMAIL_API_KEY=
